# VAPI Bridge Configuration
# Copy to .env and fill in your values.

# --- IoTeX RPC ---
IOTEX_RPC_URL=https://babel-api.testnet.iotex.io
IOTEX_CHAIN_ID=4690

# --- Contract Addresses (from deploy.js output) ---
POAC_VERIFIER_ADDRESS=0x...
BOUNTY_MARKET_ADDRESS=0x...
DEVICE_REGISTRY_ADDRESS=0x...

# --- Bridge Wallet ---
# Key source: "env" (testnet/dev, plaintext) or "keystore" (mainnet, encrypted JSON).
# Production MUST use "keystore" — never store a mainnet private key in plaintext.
BRIDGE_PRIVATE_KEY_SOURCE=env

# Plaintext private key (required when BRIDGE_PRIVATE_KEY_SOURCE=env).
# Fund this wallet with IOTX for gas. Testnet faucet: https://faucet.iotex.io/
BRIDGE_PRIVATE_KEY=0x...

# --- Bridge Wallet Keystore (production mainnet only) ---
# Required when BRIDGE_PRIVATE_KEY_SOURCE=keystore.
# Generate with: python scripts/generate_bridge_keystore.py
# Store keystore file in a secure location (not in the repo).
BRIDGE_KEYSTORE_PATH=/secure/path/bridge-keystore.json
# Name of the env var that holds the keystore decryption password.
# Set the actual password in a secrets manager or vault, never in this file.
BRIDGE_KEYSTORE_PASSWORD_ENV=BRIDGE_KEYSTORE_PASSWORD
# (Set BRIDGE_KEYSTORE_PASSWORD in your secrets manager / CI secrets, not here)

# --- MQTT ---
MQTT_ENABLED=true
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=vapi/poac
MQTT_USERNAME=
MQTT_PASSWORD=

# --- CoAP ---
COAP_ENABLED=false
COAP_BIND=0.0.0.0
COAP_PORT=5683

# --- HTTP API / Dashboard ---
HTTP_ENABLED=true
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# --- Batching ---
# Records are accumulated until batch_size is reached or batch_timeout expires.
BATCH_SIZE=10
BATCH_TIMEOUT_S=30

# --- Retry ---
MAX_RETRIES=5
RETRY_BASE_DELAY_S=2.0

# --- Storage ---
# SQLite database path. Default: ~/.vapi/bridge.db
DB_PATH=

# --- Logging ---
LOG_LEVEL=INFO

# --- Phase 19: Device Profile (Universal Controller Abstraction) ---
# Override auto-detection with an explicit profile slug. Leave empty for auto-detect.
# Examples: sony_dualshock_edge_v1 | scuf_reflex_pro_v1 | battle_beaver_dualshock_edge_v1
#           hori_fighting_commander_ps5_v1 | sony_dualsense_v1
DEVICE_PROFILE_ID=
# Set to false to disable USB HID enumeration (useful in headless/Docker environments).
AUTO_DETECT_DEVICE=true

# --- DualShock Edge Controller ---
# Set to true to enable live HID polling at ~1000 Hz (requires physical controller).
# Set to false for headless/CI environments without a controller attached.
DUALSHOCK_ENABLED=false

# --- Operator API ---
# Shared secret for all /operator/* endpoints (BridgeAgent, CalibrationIntelligenceAgent,
# gate, insights, federation, enforcement). If empty, all /operator/* return HTTP 503.
# Generate a key: python -c "import os; print(os.urandom(16).hex())"
# The same value must be set as VITE_BRIDGE_API_KEY in frontend/.env.
OPERATOR_API_KEY=

# --- Phase 237-CONSENT: Per-category gamer consent registry ---
# Address of the deployed VAPIConsentRegistry contract on IoTeX testnet.
# When set, chain.is_consent_valid(gamer, category) returns live on-chain state.
# When empty, the bridge fail-opens (returns False / empty dict) and uses the
# local consent_ledger as the operational truth — bridge does NOT block on
# missing on-chain registry.
#
# Production deploy (Phase 237-EXTEND, 2026-04-26): 0xA82dB0eF0bF7D15b6400EDd4A09C0D4338C948dA
# Mirror this in frontend/.env.local as VITE_CONSENT_REGISTRY_ADDRESS so the
# ConsentPanel UI can submit grantConsent / revokeConsent via wagmi.
CONSENT_REGISTRY_ADDRESS=

# AWS KMS credentials for VAPI Operator agent signing
# Section 6.3 implementation prerequisites
# Replace placeholder values with actual credentials and KMS
# identifiers for the deployment environment.
AWS_ACCESS_KEY_ID=AKIA-REPLACE-WITH-IAM-USER-ACCESS-KEY-ID
AWS_SECRET_ACCESS_KEY=REPLACE-WITH-IAM-USER-SECRET-ACCESS-KEY
AWS_REGION=us-east-1

# VAPI-specific KMS aliases for the two Operator agents
VAPI_KMS_ANCHOR_SENTRY_ALIAS=alias/vapi-anchor-sentry-signing
VAPI_KMS_GUARDIAN_ALIAS=alias/vapi-guardian-signing

# VAPI-specific KMS key ARNs (replace with deployment-specific
# account ID and key UUIDs)
VAPI_KMS_ANCHOR_SENTRY_ARN=arn:aws:kms:us-east-1:<account-id>:key/<anchor-sentry-key-uuid>
VAPI_KMS_GUARDIAN_ARN=arn:aws:kms:us-east-1:<account-id>:key/<guardian-key-uuid>
