# ===========================================================================
# Operator Initiative O3 Expedite — `bridge/.env` cfg-flag declarations
# ===========================================================================
#
# Status:    EXAMPLE / TEMPLATE — safe to commit (contains no secrets).
# Authored:  2026-05-15, as part of the O3 expedite arc
#            (commit 0e83a8ce + this commit).
# Purpose:   Document the 4 operator-attested cfg flags the O3 graduation
#            ceremony depends on. Operator copy-pastes these declarations
#            into `bridge/.env` (gitignored) once the underlying infrastructure
#            work has genuinely completed.
#
# How to apply:
#     cat bridge/.env.o3_expedite.example >> bridge/.env
#     # Then verify with:
#     python scripts/operator_initiative_o3_preflight.py
#
# Each flag is an OPERATOR-AUTHORED DECLARATION that the underlying work has
# completed. Mythos + the preflight CLI verify the FLAG STATE; they cannot
# verify whether the underlying infrastructure is actually in place. The
# operator owns the semantic accuracy of these declarations.
#
# These flags do NOT fire any chain tx. They are READ by `parallel_o3_act_
# anchor.py` as preconditions before the operator-runtime triple-gate
# ceremony can fire. Setting them to `true` while the kill-switch
# (CHAIN_SUBMISSION_PAUSED=true) remains armed has zero wallet impact.
# ---------------------------------------------------------------------------

# Gate 5 — Dual-key operator authorization in place (all 3 agents).
# Underlying work: operator + co-signer have established the dual-key
# infrastructure. Watcher consults this flag for ALL three Operator
# Initiative agents (anchor_sentry / guardian / curator).
OPERATOR_DUAL_KEY_PRESENT=true

# Gate 6 — AWS KMS HSM provisioned + tested (Sentry + Guardian only).
# Underlying work: production KMS HSM provisioning + Cedar bundle re-anchored
# against production keys. Curator does NOT consult this flag — Curator uses
# MockKMS testnet path on its dedicated avenue (see CLAUDE.md note "Sessions
# 1+2+3 ON-CHAIN ACTIVATION ARC COMPLETE 2026-05-09").
KMS_HSM_PRODUCTION_READY=true

# Gate 7 — Guardian GitHub App OAuth tokens valid (Guardian only).
# Underlying work: GitHub App registration + OAuth flow + valid tokens
# stored. Enables Guardian's audit-drafting workflow to write directly
# to the audits/ lane at O3_ACTING. Sentry + Curator do NOT consult this.
GITHUB_APP_OAUTH_TOKENS_VALID=true

# Gate 8 — Curator setCurator role assigned on chain (Curator only).
# Underlying work: deploy wallet calls
#   VAPIDataMarketplaceListings.setCurator(curator_agent_address)
# on contract 0x78Df84Cc512EdCaC0e58a03e4852627E2F62E3bC (Phase 238 Step H
# LIVE 2026-05-09). Cost ~0.05 IOTX testnet. The setCurator() hook was
# reserved per Phase 238 Step F. Operator temporarily lifts kill-switch
# for this single tx, then re-arms. Sentry + Guardian do NOT consult this.
MARKETPLACE_CURATOR_ROLE_ASSIGNED=true
